{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-market-maker.local/schema/nexus_payload.json",
  "title": "NexusPayload",
  "description": "Dashboard bundle: metadata, topology, traces, optional agent_prompts and message_log.",
  "type": "object",
  "required": ["metadata", "topology", "traces"],
  "additionalProperties": true,
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["run_id", "ticker", "status", "kpis"],
      "properties": {
        "run_id": { "type": "string" },
        "ticker": { "type": "string" },
        "status": { "type": "string" },
        "version": { "type": "string" },
        "pid": { "type": "integer" },
        "kpis": { "type": "object" }
      }
    },
    "topology": {
      "type": "object",
      "required": ["nodes", "edges"],
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "actor", "label", "status"],
            "properties": {
              "id": { "type": "string" },
              "actor": { "type": "string" },
              "label": { "type": "string" },
              "status": { "type": "string", "enum": ["COMPLETED", "ACTIVE", "PENDING"] },
              "summary": { "type": "string", "description": "One-line preview for directory cards" }
            }
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to"],
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" }
            }
          }
        }
      }
    },
    "traces": { "type": "array" },
    "agent_prompts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["node_id", "actor_id", "system_prompt", "task_prompt", "cot_enabled"],
        "properties": {
          "node_id": { "type": "string" },
          "actor_id": { "type": "string" },
          "system_prompt": { "type": "string" },
          "task_prompt": { "type": "string" },
          "cot_enabled": { "type": "boolean" },
          "model": { "type": "string" },
          "temperature": { "type": "number" },
          "max_tokens": { "type": "integer" },
          "tools": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "message_log": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["seq", "ts", "node_id", "actor_id", "kind", "message"],
        "properties": {
          "seq": { "type": "integer" },
          "ts": { "type": "string", "format": "date-time" },
          "node_id": { "type": "string" },
          "actor_id": { "type": "string" },
          "kind": { "type": "string", "enum": ["status", "thought", "tool", "handoff", "error"] },
          "message": { "type": "string" },
          "trace_id": { "type": "string" }
        }
      }
    }
  }
}
