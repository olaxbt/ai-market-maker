NEXT_PUBLIC_FLOW_API_BASE_URL=http://127.0.0.1:8001

BINANCE_API_KEY=your_key
BINANCE_API_SECRET=your_secret
OPENAI_API_KEY=your_openai_api_key

# OpenAI-compatible API base URL. Leave blank for OpenAI default.
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
AI_MARKET_MAKER_USE_LLM=0

# Seconds between full workflow runs when using ./start.sh (default 180 ≈ 3 min).
STRATEGY_INTERVAL_SEC=180
# Optional: OLAXBT Nexus data / quant API base URL when integrating live feeds
OLAXBT_NEXUS_DATA_BASE_URL=
# Cap steps per POST /backtests/quick (protects API from huge synchronous runs).
BACKTEST_API_MAX_STEPS=5000
TWITTER_BEARER_TOKEN=your_twitter_bearer_token