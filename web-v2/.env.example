# Copy to `.env` or `.env.local` in this folder. Only names prefixed with `VITE_` are exposed to the client bundle.

# Flow (Python) HTTP API. Vite `dev` / `preview` proxies the browser URL `/api/agent-prompts/n5` →
# `{VITE_FLOW_API_BASE_URL}/agent-prompts/n5` (strip `/api`). That is intentional, not a broken path.
# Also used in the app to derive the default WebSocket URL when `VITE_FLOW_WS_URL` is unset.
VITE_FLOW_API_BASE_URL=http://127.0.0.1:8001

# Optional: WebSocket URL for live Nexus/console traces. If omitted, it is derived from `VITE_FLOW_API_BASE_URL`
# (http→ws, https→wss) with path `/ws/runs/latest`. Set the full URL if your deployment uses a custom path.
# VITE_FLOW_WS_URL=ws://127.0.0.1:8001/ws/runs/latest
